{
  "name": "sellio",
  "version": "0.0.1",
  "private": true,
  "description": "Sellio — Loyalty cards para comercios en Colombia",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @sellio/db migrate",
    "db:reset": "pnpm --filter @sellio/db reset",
    "db:seed": "pnpm --filter @sellio/db seed",
    "db:types": "pnpm --filter @sellio/db types"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "types-react": "npm:@types/react@^18.3.28",
      "types-react-dom": "npm:@types/react-dom@^18.3.4",
      "@types/react@>18": "18.3.28",
      "@types/react-dom@>18": "18.3.4"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
