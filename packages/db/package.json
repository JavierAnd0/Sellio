{
  "name": "@sellio/db",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./admin": "./src/admin.ts",
    "./types": "./src/types.ts",
    "./repositories": "./src/repositories/index.ts"
  },
  "scripts": {
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "supabase db push",
    "reset": "supabase db reset",
    "seed": "tsx scripts/seed.ts",
    "types": "supabase gen types typescript --local > src/types.generated.ts"
  },
  "dependencies": {
    "@sellio/domain": "workspace:*",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3"
  },
  "devDependencies": {
    "@sellio/config": "workspace:*",
    "@types/node": "^20.16.11",
    "next": "^16.2.4",
    "supabase": "^1.207.9",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
