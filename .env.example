# ============================================================
# Sellio — Variables de entorno de ejemplo
# Copiar a .env.local y completar con valores reales:
#   cp .env.example .env.local
# NUNCA commitear .env.local
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Obtener en: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo en Route Handlers y Server Actions — nunca en cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Para migraciones con Supabase CLI
SUPABASE_DB_URL=postgresql://postgres:[password]@db.<project-ref>.supabase.co:5432/postgres

# ── QR ───────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
QR_SIGNING_SECRET=

# ── Wompi (pagos COP) ────────────────────────────────────────
# Obtener en: https://comercios.wompi.co → Developers
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_SECRET=
WOMPI_SANDBOX=true

# ── Resend (email) ───────────────────────────────────────────
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── URLs de las apps ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CARDS_URL=http://localhost:3001

# ── Sentry (observabilidad) ──────────────────────────────────
# Opcional en development; requerido en producción
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Google Wallet ─────────────────────────────────────────────
# 1. Habilita la API "Google Wallet API" en Google Cloud Console
# 2. Crea una Service Account y descarga el JSON de credenciales
# 3. Ve a Google Pay & Wallet Console → crea un Issuer Account → obtén el Issuer ID
#
# GOOGLE_WALLET_ISSUER_ID      ── número de 13 dígitos (ej: 3388000000022961234)
# GOOGLE_WALLET_CLASS_ID       ── sufijo del Class ID (default: sellio_loyalty)
# GOOGLE_SERVICE_ACCOUNT_EMAIL ── email de la service account del JSON
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY ── campo "private_key" del JSON (con \n literales)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_CLASS_ID=sellio_loyalty
GOOGLE_SERVICE_ACCOUNT_EMAIL=sellio-wallet@<project>.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# ── Apple Wallet (scaffold — requiere Apple Developer Account) ─
# 1. Enrólate en Apple Developer Program (developer.apple.com)
# 2. Crea un Pass Type ID en Certificates, IDs & Profiles
# 3. Genera un Pass Type Certificate y expórtalo como .p12
# 4. Descarga Apple WWDR G4 (https://www.apple.com/certificateauthority)
# 5. Convierte ambos a base-64: base64 -i cert.p12
#
# APPLE_PASS_TYPE_IDENTIFIER   ── ej: pass.com.sellio.loyalty
# APPLE_TEAM_IDENTIFIER        ── ej: ABC1234DEF  (en Apple Dev Portal)
# APPLE_PASS_CERTIFICATE       ── base-64 del .p12
# APPLE_PASS_CERTIFICATE_PWD   ── contraseña del .p12
# APPLE_WWDR_CERTIFICATE       ── base-64 del cert WWDR G4
APPLE_PASS_TYPE_IDENTIFIER=
APPLE_TEAM_IDENTIFIER=
APPLE_PASS_CERTIFICATE=
APPLE_PASS_CERTIFICATE_PWD=
APPLE_WWDR_CERTIFICATE=
